# GitHub App auth (used by MCP tools)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=/absolute/path/to/your-github-app-private-key.pem
GITHUB_INSTALLATION_ID=12345678
GITHUB_CLIENT_ID=Iv1xxxxxxxxxxxxxxxxx

# GitHub App webhook proxy -> OpenClaw hooks
GITHUB_WEBHOOK_SECRET=replace_with_strong_random_secret
OPENCLAW_WEBHOOK_URL=http://127.0.0.1:18789/hooks/github
OPENCLAW_HOOKS_TOKEN=replace_with_openclaw_hooks_token
WEBHOOK_PROXY_PATH=/gh-webhook
WEBHOOK_PROXY_BODY_LIMIT=1mb
